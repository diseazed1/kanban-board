{
  "name": "kanban-board",
  "version": "2.0.0",
  "description": "Kanban board with PostgreSQL, Argon2id auth, admin user management, per-card publish control, SendGrid invites, and Fly.io deployment.",
  "main": "server.mjs",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "start": "node server.mjs",
    "dev": "NODE_ENV=development node --watch server.mjs",
    "seed-admin": "node seed_admin.js",
    "db:schema": "psql $DATABASE_URL -f schema.sql",
    "db:seed-columns": "psql $DATABASE_URL -f columns_default.sql"
  },
  "dependencies": {
    "@sendgrid/mail": "^8.1.3",
    "argon2": "^0.41.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.13.3"
  }
}
