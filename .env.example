# =============================================================================
# Kanban Board — Environment Variables
#
# Copy this file to .env for local development:
#   cp .env.example .env
#
# For production (Fly.io), set these via:
#   fly secrets set KEY=value
#
# NEVER commit .env or any file containing real secrets to version control.
# =============================================================================

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
# PostgreSQL connection string.
# Local dev example: postgres://postgres:password@localhost:5432/kanban
# Fly.io example:    postgres://kanban:password@kanban-db.internal:5432/kanban
DATABASE_URL=postgres://postgres:password@localhost:5432/kanban

# ---------------------------------------------------------------------------
# Session Secret
# ---------------------------------------------------------------------------
# A long, random string used to sign session cookies.
# Generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=replace-with-a-long-random-secret-string

# ---------------------------------------------------------------------------
# SendGrid email
# ---------------------------------------------------------------------------
# Your SendGrid API key (starts with "SG.")
SENDGRID_API_KEY=SG.your-sendgrid-api-key-here

# The verified sender address configured in your SendGrid account
FROM_EMAIL=no-reply@yourdomain.com

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
# The public URL of your app (no trailing slash).
# Used to build invite registration links in emails.
APP_URL=https://your-app-name.fly.dev

# Optional: displayed in invite email subject lines
APP_NAME=Kanban Board

# Port the server listens on (Fly.io sets this automatically)
PORT=3000

# Set to "production" in deployed environments
NODE_ENV=development

# ---------------------------------------------------------------------------
# Audit Log Retention
# ---------------------------------------------------------------------------
# Number of days to keep audit log entries before automatic purging.
# Entries older than this are deleted daily. Default: 90 days.
AUDIT_LOG_RETENTION_DAYS=90
